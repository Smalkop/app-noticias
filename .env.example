# JWT_SECRET: Secret for signing JSON Web Tokens.
JWT_SECRET="changeme_secret_key"

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# VITE_GOOGLE_CLIENT_ID: Your Google OAuth 2.0 Client ID for Google Login.
VITE_GOOGLE_CLIENT_ID="299900031060-silb41p24p4bm72tl5sfn1j5lfvgad36.apps.googleusercontent.com"

# SendPulse: For newsletter integration
'id sendpulse'=
'secret sendpulse'=
SENDPULSE_LIST_ID=
